# Stendly SDK Configuration
# Copy this file to .env and fill in your values

# API Key (get from https://dashboard.stendly.com)
# Use st_live_ prefix for both mainnet and devnet
STENDLY_API_KEY=st_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook secret (for verifying webhooks)
# Found in merchant dashboard under Webhooks section
STENDLY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# Environment (mainnet or devnet)
STENDLY_ENVIRONMENT=mainnet

# Optional: Custom API base URL (leave empty for default)
# STENDLY_BASE_URL=
