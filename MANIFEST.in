include LICENSE
include README.md
include CHANGELOG.md
include CONTRIBUTING.md
include pyproject.toml

recursive-include docs *.md
recursive-include tests *.py

global-exclude:
    *.pyc
    __pycache__
    .DS_Store
    *.egg-info
    .pytest_cache
    .coverage
    htmlcov
    .mypy_cache
    .ruff_cache
